{
  "name": "neetcode-ts",
  "version": "0.1.0",
  "description": "TypeScript playground for solving NeetCode / LeetCode problems with auto-scaffolded folders and tests.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "new": "tsx scripts/new.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "solve": "tsx scripts/solve.ts",
    "progress": "tsx scripts/list.ts",
    "next": "tsx scripts/next.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
